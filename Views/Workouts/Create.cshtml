@model TrainingLog.Models.Workout

@{
    ViewData["Title"] = "Add Workout";
}

<h2>Add Workout</h2>

<form asp-action="Create">
    <div>
        <label asp-for="AthleteId"></label>
        <select asp-for="AthleteId">
            @foreach (var athlete in ViewBag.Athletes)
            {
                <option value="@athlete.AthleteId">@athlete.Name</option>
            }
        </select>
        <span asp-validation-for="AthleteId"></span>
    </div>
    <div>
        <label asp-for="Date"></label>
        <input asp-for="Date" />
        <span asp-validation-for="Date"></span>
    </div>
    <div>
        <label asp-for="DurationMinutes"></label>
        <input asp-for="Notes"></textarea>
        <span asp-validation-for="Notes"></span>
    </div>
    <div>
        <input type="submit" value="Save" />
        <a asp-action="Index">Back to List</a>
    </div>
</form>