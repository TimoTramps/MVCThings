@model IEnumerable<TrainingLog.Models.Workout>

@{
    ViewData["Title"] = "Workouts";
}

<h2>Workouts</h2>

<a asp-action="Create">Add New Workout</a>

<table>
    <thead>
        <tr>
            <th>Sportsperson</th>
            <th>Date</th>
            <th>Duration</th>
            <th>Notes</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Athlete?.Name</td>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.DurationMinutes</td>
                <td>@item.Notes</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.WorkoutId">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.WorkoutId">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.WorkoutId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
