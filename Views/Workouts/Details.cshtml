@model TrainingLog.Models.Workout

@{
    ViewData["Title"] = "Workout Details";
}

<h2>Workout Details</h2>

<div>
    <label>Athlete:</label>
    <span>@Model.Athlete?.Name</span>
</div>
<div>
    <label>Date:</label>
    <span>@Model.Date.ToShortDateString()</span>
</div>
<div>
    <label>Duration:</label>
    <span>@Model.DurationMinutes min</span>
</div>
<div>
    <label>Notes:</label>
    <span>@Model.Notes</span>
</div>

<a asp-action="Edit" asp-route-id="@Model.WorkoutId">Edit</a>
<a asp-action="Index">Back to List</a>