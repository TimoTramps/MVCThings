@model IEnumerable<TrainingLog.Models.Athlete>

@{
    ViewData["Title"] = "Athletes";
}

<h2>Athletes</h2>

<a asp-action="Create">Add New Athlete</a>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Position</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Age</td>
                <td>@item.Position</td>
                <td>@item.CreatedAt.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.AthleteId">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.AthleteId">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.AthleteId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>